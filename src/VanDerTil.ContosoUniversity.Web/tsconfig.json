{
  "compileOnSave": true,
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": true,
    "sourceMap": true,
    "target": "es2019",
    "rootDir": "Features",
    "outDir": "wwwroot/js"
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "wwwroot",
    "node_modules"
  ]
}
